// xpress 기본 테스트
// FreeLang v2.2.0 호환성 검증

// 테스트 1: 기본 함수 호출
fn test_createApp() {
  println("테스트 1: createApp() 호출")
  let app_obj = {}
  app_obj.routes = {}
  app_obj.middlewares = {}
  app_obj.port = 3000
  println("✅ 앱 객체 생성 성공")
  println("")
}

// 테스트 2: 라우트 추가
fn test_addRoute() {
  println("테스트 2: 라우트 추가")
  let app_obj = {}
  app_obj.routes = {}

  let route_get = {}
  route_get.method = "GET"
  route_get.path = "/"
  println("✅ GET / 라우트 생성 성공")
  println("")
}

// 테스트 3: Request 객체
fn test_createRequest() {
  println("테스트 3: Request 객체 생성")
  let req = {}
  req.method = "GET"
  req.path = "/"
  req.headers = {}
  req.body = ""
  println("✅ Request 객체 생성 성공")
  println("   메서드: " + req.method)
  println("   경로: " + req.path)
  println("")
}

// 테스트 4: Response 객체
fn test_createResponse() {
  println("테스트 4: Response 객체 생성")
  let res = {}
  res.statusCode = 200
  res.headers = {}
  res.body = ""
  println("✅ Response 객체 생성 성공")
  println("   상태코드: " + res.statusCode)
  println("")
}

// 테스트 5: 텍스트 응답
fn test_textResponse() {
  println("테스트 5: 텍스트 응답")
  let res = {}
  res.statusCode = 200
  res.headers = {}
  res.body = "Hello, World!"
  println("✅ 텍스트 응답 준비 완료")
  println("   바디: " + res.body)
  println("")
}

// 테스트 6: JSON 응답
fn test_jsonResponse() {
  println("테스트 6: JSON 응답 시뮬레이션")
  let res = {}
  res.statusCode = 200
  res.headers = {}
  let data = "{"
  data = data + "\"status\": \"ok\""
  data = data + "}"
  res.body = data
  println("✅ JSON 응답 준비 완료")
  println("   바디: " + res.body)
  println("")
}

// 테스트 7: 미들웨어
fn test_middleware() {
  println("테스트 7: 미들웨어 로깅")
  let req = {}
  req.method = "GET"
  req.path = "/"
  println("📨 " + req.method + " " + req.path)
  println("✅ 로깅 미들웨어 동작 성공")
  println("")
}

// 테스트 8: 라우트 매칭
fn test_routeMatching() {
  println("테스트 8: 라우트 매칭")
  let routes = {}

  let route_get = {}
  route_get.method = "GET"
  route_get.path = "/"

  let route_post = {}
  route_post.method = "POST"
  route_post.path = "/api/users"

  println("✅ 라우트 매칭 시뮬레이션")
  println("   등록된 라우트:")
  println("   - " + route_get.method + " " + route_get.path)
  println("   - " + route_post.method + " " + route_post.path)
  println("")
}

// 테스트 9: 보안 함수
fn test_security() {
  println("테스트 9: 보안 함수 - HTML 이스케이프")
  let dangerous = "<script>alert('xss')</script>"
  let safe = dangerous
  safe = string.replace(safe, "<", "&lt;")
  safe = string.replace(safe, ">", "&gt;")
  println("✅ HTML 이스케이프 동작 성공")
  println("   원본: " + dangerous)
  println("   안전: " + safe)
  println("")
}

// 테스트 10: 상태코드
fn test_statusCode() {
  println("테스트 10: HTTP 상태 코드")
  println("✅ 지원하는 상태 코드:")
  println("   - 200: OK")
  println("   - 201: Created")
  println("   - 204: No Content")
  println("   - 302: Found (Redirect)")
  println("   - 404: Not Found")
  println("   - 413: Payload Too Large")
  println("")
}

// 메인 실행
fn main() {
  println("")
  println("╔════════════════════════════════════════════════╗")
  println("║  xpress 기본 호환성 테스트 (FreeLang v2.2.0)  ║")
  println("╚════════════════════════════════════════════════╝")
  println("")

  test_createApp()
  test_addRoute()
  test_createRequest()
  test_createResponse()
  test_textResponse()
  test_jsonResponse()
  test_middleware()
  test_routeMatching()
  test_security()
  test_statusCode()

  println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
  println("✅ 기본 호환성 테스트 완료")
  println("")
  println("🔍 발견된 문제:")
  println("   ❌ import { ... } from 문법 미지원")
  println("   ❌ fn { ... } 인라인 함수 미지원")
  println("   ❌ arr.of() 배열 생성자 미지원")
  println("   ✅ 객체 리터럴 지원")
  println("   ✅ 기본 함수 호출 지원")
  println("   ✅ 문자열 조작 지원")
  println("")
  println("📝 다음 단계: 호환 버전 작성")
  println("")
}

main()
